{
  "name": "notes",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist-server/electron.js",
  "scripts": {
    "dev": "concurrently -n fe,be -c cyan,green \"npm run dev:fe\" \"npm run dev:be\"",
    "dev:fe": "vite",
    "dev:be": "tsx watch server/main.ts",
    "build": "npm run build:exe",
    "build:frontend": "vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "build:exe": "build",
    "build:apk": "echo TODO: APK build - not yet implemented",
    "preview": "vite preview",
    "type-check": "vue-tsc --build && tsc --noEmit -p server/tsconfig.json"
  },
  "dependencies": {
    "adm-zip": "^0.6.0",
    "axios": "^1.16.1",
    "cors": "^2.8.5",
    "dompurify": "^3.4.9",
    "element-plus": "^2.14.1",
    "express": "^4.21.0",
    "github-markdown-css": "^5.9.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "marked": "^18.0.5",
    "marked-highlight": "^2.2.4",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.73.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/adm-zip": "^0.5.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^9.1.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.0",
    "npm-run-all2": "^8.0.4",
    "tsx": "^4.19.0",
    "typescript": "~6.0.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.8",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
